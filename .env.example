# Clerk Authentication
# Find these in your Clerk Dashboard: https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Neon Database (PostgreSQL)
# Get your connection string from the Neon Console: https://console.neon.tech/
DATABASE_URL=postgresql://user:password@hostname/dbname?sslmode=require

# Application-level encryption for sensitive field values (32-byte key, base64)
FIELD_VALUE_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32

# Cloudflare R2 (template storage)
R2_BUCKET_NAME=avia-modelos
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Admin users (comma-separated emails)
ADMIN_EMAILS=myemail@gmail.com

# AI provider for admin template preparation
# Available providers: gemini, groq, mock
AI_TEMPLATE_PROVIDER=groq
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
